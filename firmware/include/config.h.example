/**
 * config.h.example — TremoAI Smart Glove Firmware Configuration Template
 *
 * SETUP INSTRUCTIONS:
 *   1. Copy this file to firmware/include/config.h
 *   2. Fill in all placeholder values below
 *   3. DO NOT commit config.h to version control (it is .gitignored)
 *
 * Feature: 025-imu-kalman-fusion (IMU + Kalman filter)
 * Feature: 030-esp32-mqtt       (WiFi + MQTT publish pipeline)
 * Feature: 031-freertos-scheduler (FreeRTOS tasks, PID tremor control, CMG actuation)
 * Feature: 042-mpu6500-firmware-upgrade (MPU6500 SPI sensor, GPIO13/14 actuator pin reassignment)
 */

#pragma once

// ─── Device Identity ─────────────────────────────────────────────────────────
// Must match the serial number registered in the TremoAI Django admin
// Format: 8–20 uppercase alphanumeric characters (e.g., "GLOVE001A")
#define DEVICE_SERIAL   "YOUR_DEVICE_SERIAL"

// ─── WiFi Credentials ────────────────────────────────────────────────────────
#define WIFI_SSID       "your_wifi_ssid"
#define WIFI_PASSWORD   "your_wifi_password"

// ─── MQTT Broker ─────────────────────────────────────────────────────────────
// Point to the host running the Mosquitto broker.
// In development: typically the same machine running Django backend.
#define MQTT_BROKER_HOST  "192.168.1.100"   // Replace with broker LAN IP
#define MQTT_BROKER_PORT  1883
#define MQTT_USERNAME     ""                 // Leave empty if no auth required
#define MQTT_PASSWORD     ""                 // Leave empty if no auth required

// ─── IMU Sampling ─────────────────────────────────────────────────────────────
#define IMU_SAMPLE_RATE_HZ    100            // Target: 100 Hz (Kalman filter input rate)
#define IMU_SAMPLE_PERIOD_MS  10             // 1000 / IMU_SAMPLE_RATE_HZ

// ─── MQTT Publish Rate ────────────────────────────────────────────────────────
// IMU runs at 100 Hz; MQTT publishes at a lower rate to meet 30-50 Hz spec.
// A millis() guard in loop() throttles publish to this rate.
// Default 33 Hz → 1 publish every ~30 ms (within 30-50 Hz spec).
#define MQTT_PUBLISH_RATE_HZ  33             // Target: 30-50 Hz per spec

// ─── Battery ADC ──────────────────────────────────────────────────────────────
// MUST be an ADC1 pin (GPIO32–39). ADC2 pins are unreliable when WiFi is active.
// Default: GPIO34 (input-only, no conflicts, ADC1 channel 6).
//
// Wiring: Battery+ → R1 (100kΩ) → BATTERY_ADC_PIN → R2 (47kΩ) → GND
//   Divider ratio = R2 / (R1 + R2) = 47 / (100 + 47) ≈ 0.3197
//   At 4.2V (full): ADC pin sees 4.2 × 0.3197 ≈ 1.34V (within 0–3.3V range)
//   At 3.0V (empty): ADC pin sees 3.0 × 0.3197 ≈ 0.96V
//
// analogSetAttenuation(ADC_11db) must be called in battery_init() to cover 0–3.3V.
#define BATTERY_ADC_PIN       34             // GPIO34 — ADC1 channel 6 (input-only)
#define BATTERY_DIVIDER_RATIO (47.0f / 147.0f)   // R2 / (R1 + R2) — adjust for your resistors
#define BATTERY_V_MIN         3.0f          // LiPo empty voltage (0%)
#define BATTERY_V_MAX         4.2f          // LiPo full voltage (100%)

// ─── Startup Calibration ──────────────────────────────────────────────────────
// Collect CALIB_N_SAMPLES samples (glove must be stationary during this window)
// At 100 Hz, 500 samples = 5 seconds of stationary data
#define CALIB_N_SAMPLES         500
// Motion guard: if gyro range (max-min) over window exceeds threshold * 5.0 deg/s, calibration fails
#define GYRO_MOTION_THRESHOLD   10.0f        // deg/s per-sample threshold

// ─── Kalman Filter Tuning ─────────────────────────────────────────────────────
// Default values from Lauszus reference implementation.
// Tune R_measure up (0.05–0.15) if output is jittery during hand movement.
// Tune Q_bias up if gyro drift changes rapidly (temperature swings).
#define KF_Q_ANGLE          0.001f   // Process noise: angle state (deg^2)
#define KF_Q_BIAS           0.003f   // Process noise: gyro bias drift (deg^2/s)
#define KF_R_MEASURE        0.03f    // Measurement noise: static accel angle (deg^2)
#define KF_R_MEASURE_DYNAMIC 0.09f  // Measurement noise during dynamic motion (3x static)
// Dynamic threshold: if |‖a‖ - 9.80665| > 2.943 m/s² (≈0.3g), use KF_R_MEASURE_DYNAMIC
#define KF_ACCEL_DYNAMIC_THRESHOLD_MS2  2.943f

// ─── MPU6500 SPI Pins ─────────────────────────────────────────────────────────
// Uses ESP32 VSPI peripheral. None of these pins may equal 12 or 14
// (those are reserved for CMG actuators below).
#define MPU6500_SPI_SCK   18      // VSPI clock  — freed from former CMG gimbal pin
#define MPU6500_SPI_MISO  19      // VSPI MISO   — freed from former CMG flywheel pin
#define MPU6500_SPI_MOSI  23      // VSPI MOSI
#define MPU6500_SPI_CS     5      // VSPI chip-select (active LOW)
#define MPU6500_SPI_FREQ  1000000 // 1 MHz — conservative, safe for glove wiring

// LED pin for fault indication (optional, -1 to disable)
#define FAULT_LED_PIN   2      // ESP32 built-in LED on GPIO 2

// ─── CMG Actuation ────────────────────────────────────────────────────────────
// ESP32 Arduino 2.x uses channel-based LEDC API: ledcSetup + ledcAttachPin + ledcWrite(channel)
// CMG_GIMBAL_CHANNEL and CMG_FLYWHEEL_CHANNEL are used by cmg.cpp.
// GPIO12 and GPIO14 are exclusively reserved for actuators — never assign SPI here.
#define CMG_GIMBAL_PIN        12      // GPIO12 — gimbal servo signal
#define CMG_GIMBAL_CHANNEL     0      // LEDC channel 0 (unused in Arduino 3.x, kept for reference)
#define CMG_FLYWHEEL_PIN      14      // GPIO14 — flywheel ESC signal
#define CMG_FLYWHEEL_CHANNEL   1      // LEDC channel 1 (unused in Arduino 3.x, kept for reference)
#define CMG_PWM_FREQ_HZ       50      // 50Hz (servo/ESC standard)
#define CMG_PWM_RESOLUTION    16      // 16-bit duty (0–65535); duty = pulse_us × 65536 / 20000

// Gimbal geometry — torque [-1,+1] maps directly to a pulse width (no degree abstraction)
// Feature 053 (US1): full-range linear mapping. SPAN is the HALF-swing, so it must equal
// (CENTER-MIN)=(MAX-CENTER)=900 -> torque ±1.0 lands exactly on the 600/2400 clamps (no dead band).
#define CMG_GIMBAL_CENTER_US  1500    // µs pulse at zero torque
#define CMG_GIMBAL_TRIM_US       0    // shift mechanical neutral; keep small (±100µs)
#define CMG_GIMBAL_SPAN_US     900    // µs half-swing for full ±1.0 torque (was 600)
#define CMG_GIMBAL_MIN_US      600    // hard clamp — physical servo-safe minimum (was 900)
#define CMG_GIMBAL_MAX_US     2400    // hard clamp — physical servo-safe maximum (was 2100)

// ESC arm/run sequence — fixed constant throttle, no retry or spin-up verification
#define CMG_ESC_ARM_MS         5000   // ms to hold the arm pulse before commanding the run pulse
#define CMG_ESC_ARM_PULSE_US   1000   // µs arm/idle pulse
// Feature 053 (US1): RAISE flywheel speed for reaction-torque authority (τ = H·ω_gimbal, H∝Ω).
// Start 1200; bench-tune UP to the highest value with no brownout/reset/ESC re-arm.
#define CMG_ESC_RUN_PULSE_US   1200   // µs constant flywheel run pulse (was 1080)

// Torque normalization and slew limiting (cmg_set_gimbal())
// Feature 053 (US1): un-squash the PID->CMG signal (snappier saturation + faster full-range swing).
#define CMG_TORQUE_FULL_SCALE   80.0f // divides raw PID output into normalized torque [-1,1] (was 160)
#define CMG_TORQUE_SLEW_PER_S  150.0f // max torque change per second (was 40) — caps current ramp

// ─── PID Controller Tuning ────────────────────────────────────────────────────
// Feedback: gyro angular velocity (gY — see Tremor Axis Select below), setpoint = 0 deg/s.
// Values validated on the bench (run_zizo): raw finite-difference derivative, no
// pre-filter or deadband, simple fixed integral clamp (see PID_INTEGRAL_CLAMP).
#define PID_KP                2.0f   // Proportional gain
#define PID_KI                0.0f   // Integral gain — disabled for initial tuning
#define PID_KD               0.05f   // Derivative gain — primary damping term
#define PID_INTEGRAL_CLAMP  100.0f   // Anti-windup: hard clamp on accumulated integral

// Fixed control-loop period (200Hz ControlTask) — shared by pid_init()'s dt and
// the CMG slew limiter so both use the same control-rate assumption.
#define CONTROL_LOOP_DT_S    0.005f

// ─── Tremor Axis Select ───────────────────────────────────────────────────────
// Set to AXIS_GX for roll-rate (pronation/supination) or AXIS_GY for pitch-rate. Recompile to switch.
#define AXIS_GX             0
#define AXIS_GY             1
#define TARGET_TREMOR_AXIS  AXIS_GY

// ─── FreeRTOS Task Stack Sizes ────────────────────────────────────────────────
#define SENSOR_TASK_STACK   6144     // bytes — IMU read + Kalman filter + SPI driver call depth
#define CONTROL_TASK_STACK  5120     // bytes — PID computation (LPF + deadband state) + CMG LEDC write
#define MQTT_TASK_STACK     8192     // bytes — JSON serialization + MQTT library

// ─── 052-edge-ai-inference: On-Device Tremor Classifier ───────────────────────
// The glove classifies movement locally (Feature 053 BINARY: Non-Tremor=0, Tremor=1) and gates PID
// suppression proportionally to the Tremor probability. The constants (EDGE_*, CLASSIFY_*, GATE_*) live in
// the COMMITTED header firmware/include/edge_config.h (so they exist even with an old config.h).
// To tune the gate/cadence, either edit edge_config.h or override a value by #define-ing it here
// BEFORE the firmware includes edge_config.h. Example override:
//   #define GATE_MIN_DWELL_MS 600   // longer anti-chatter dwell
//   #define EDGE_GATE_ENABLED false  // rollback to legacy always-on suppression
